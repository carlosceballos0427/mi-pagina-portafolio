---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { 
	title, 
	description = "Portafolio profesional de Carlos Andrés Ceballos Santos - Ingeniero Industrial, Especialista en BI & Big Data, y Desarrollador de Inteligencia Artificial." 
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Optimization -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="Carlos Andrés Ceballos, Carlos Ceballos, Buscador SECOP, UAG Control, Ingeniero Industrial, Business Intelligence, Big Data, Desarrollador IA, React, Astro, Django, Python" />
		<meta name="author" content="Carlos Andrés Ceballos Santos" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content="https://www.buscadorsecop.com/" />
		<meta property="og:site_name" content="Carlos Ceballos Portfolio" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<!-- Typography (Sora for Headings, Outfit for Body & UI) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="relative min-h-screen bg-bg-dark overflow-x-hidden antialiased grid-bg-overlay">
		<slot />
	</body>
</html>
